{
  "name": "scaffolding-templates",
  "license": "ISC",
  "author": "Sean McQuaid",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "bundlesize": "turbo bundlesize",
    "clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "start": "turbo start",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:watch": "turbo test:watch",
    "playwright:run-integration": "turbo playwright:run-integration",
    "playwright:run-e2e": "turbo playwright:run-e2e"
  },
  "devDependencies": {
    "turbo": "^2.10.5"
  }
}