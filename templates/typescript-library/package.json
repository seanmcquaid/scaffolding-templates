{
  "name": "typescript-library",
  "version": "0.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "bundlesize": "bundlesize",
    "changeset": "changeset",
    "check-treeshaking": "agadoo dist/index.js",
    "check-types": "npm pack && attw --pack --ignore-rules cjs-resolves-to-esm",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "release": "pnpm build && changeset publish",
    "intent:validate": "intent validate",
    "intent:stale": "intent stale",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.2",
    "@tanstack/intent": "^0.0.29",
    "@vitest/eslint-plugin": "^1.6.15",
    "@vitest/coverage-istanbul": "^4.1.4",
    "agadoo": "^3.0.0",
    "bundlesize2": "^0.0.35",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.4.0",
    "dpdm": "^4.0.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.12.0"
  }
}
