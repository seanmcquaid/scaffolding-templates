{
  "name": "typescript-library",
  "version": "0.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist",
    "skills"
  ],
  "scripts": {
    "build": "tsdown",
    "bundlesize": "bundlesize",
    "changeset": "changeset",
    "check-treeshaking": "agadoo dist/index.js",
    "check-types": "npm pack && attw --pack --ignore-rules cjs-resolves-to-esm",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "release": "pnpm build && changeset publish",
    "intent:validate": "intent validate",
    "intent:stale": "intent stale",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@tanstack/intent": "^0.3.3",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vitest/coverage-istanbul": "^4.1.9",
    "agadoo": "^3.0.0",
    "bundlesize2": "^0.0.35",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.0.8",
    "dpdm": "^4.2.0",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
